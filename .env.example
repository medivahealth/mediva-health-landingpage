# Copy this file to ".env" in the SAME folder as package.json (project root).
# Never commit .env — it is gitignored.

PORT=3000
NODE_ENV=development

# --- MongoDB (recommended for production / Vercel) ---
# Get URI from MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# --- Admin dashboard (CHANGE THESE IN PRODUCTION) ---
ADMIN_EMAIL=mediva@admin.com
ADMIN_PASSWORD=Mediva@123

# --- Sessions (REQUIRED for production: long random string, 32+ characters) ---
SESSION_SECRET=change-me-to-long-random-string-min-32-characters-for-security

# --- Optional: JSON fallback storage path (only if NOT using MongoDB) ---
# DATA_DIR=
